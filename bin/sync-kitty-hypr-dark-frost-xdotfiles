#!/usr/bin/env bash
# hypr-dark-frost-xdotfiles — Kitty colors/fonts.
set -euo pipefail

colors="${HOME}/.cache/ambxst/colors.json"
theme="${HOME}/.config/ambxst/config/theme.json"
kitty_dir="${HOME}/.config/kitty"
out="${kitty_dir}/hypr-dark-frost-xdotfiles-generated.conf"
# shellcheck source=/dev/null
source "${HOME}/.local/share/hypr-dark-frost-xdotfiles/font-stack.sh"

if [[ ! -f "$colors" ]]; then
    echo "Shell colors not found at $colors" >&2
    exit 1
fi

read_color() {
    jq -r ".[\"$1\"] // empty" "$colors"
}

bg="$(read_color background)"
fg="$(read_color overBackground)"
surface="$(read_color surface)"
surface_high="$(read_color surfaceContainerHigh)"
surface_highest="$(read_color surfaceContainerHighest)"
surface_container="$(read_color surfaceContainer)"
primary="$(read_color primary)"
outline="$(read_color outlineVariant)"
muted="$(read_color overSurfaceVariant)"
error="$(read_color error)"
secondary="$(read_color secondary)"

hdf_x_font_stack
mono_font="${HDF_X_MONO_FONT}"
mono_size="${HDF_X_MONO_SIZE}"

mkdir -p "$kitty_dir"

cat >"$out" <<EOF
# Generated by hypr-dark-frost-xdotfiles — rerun: sync-kitty-hypr-dark-frost-xdotfiles

# Colors
foreground                      ${fg}
background                      ${bg}
selection_foreground            ${fg}
selection_background            ${surface_highest}

cursor                          ${primary}
cursor_text_color               ${bg}

url_color                       ${secondary}

# Tabs
active_tab_foreground           ${bg}
active_tab_background           ${primary}
inactive_tab_foreground         ${muted}
inactive_tab_background         ${surface}
tab_bar_background              ${surface_container}
tab_bar_margin_color            ${bg}

# Window border (inactive / active)
active_border_color             ${outline}
inactive_border_color           ${surface_high}

# Bell
visual_bell_color               ${error}

# ANSI — muted palette that fits the dark grey Hypr Dark Frost X look
color0                          ${surface}
color8                          ${outline}
color1                          #f07178
color9                          #ff8a90
color2                          #98c379
color10                         #b5e08a
color3                          #e5c07b
color11                         #f0d090
color4                          #7ab0df
color12                         #9ec8ff
color5                          #c792ea
color13                         #d4a8ff
color6                          #56b6c2
color14                         #7dd8df
color7                          ${fg}
color15                         #ffffff
EOF

# Patch static kitty.conf font lines if present
if [[ -f "${kitty_dir}/kitty.conf" ]]; then
    sed -i \
        -e "s/^font_family .*/font_family ${mono_font}/" \
        -e "s/^bold_font .*/bold_font auto/" \
        -e "s/^italic_font .*/italic_font auto/" \
        -e "s/^font_size .*/font_size ${mono_size}.0/" \
        "${kitty_dir}/kitty.conf" 2>/dev/null || true
fi

echo "Updated Kitty theme (${mono_font} ${mono_size}pt)"
