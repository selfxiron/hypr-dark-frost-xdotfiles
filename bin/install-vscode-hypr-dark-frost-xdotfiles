#!/usr/bin/env bash
# hypr-dark-frost-xdotfiles — install VS Code + frost theme.
set -euo pipefail

if ! command -v code >/dev/null 2>&1; then
    echo "Installing code from extra..."
    sudo pacman -S --needed --noconfirm code
fi

if ! command -v gnome-keyring-daemon >/dev/null 2>&1; then
    echo "Installing gnome-keyring (Secret Service for VS Code auth)..."
    sudo pacman -S --needed --noconfirm gnome-keyring
fi

if systemctl --user is-system-running >/dev/null 2>&1; then
    systemctl --user enable --now gnome-keyring-daemon.socket gnome-keyring-daemon.service 2>/dev/null || true
fi

chmod +x "${HOME}/.local/bin/sync-vscode-hypr-dark-frost-xdotfiles"
chmod +x "${HOME}/.local/bin/code"
chmod +x "${HOME}/.local/bin/ensure-gnome-keyring"
"${HOME}/.local/bin/sync-vscode-hypr-dark-frost-xdotfiles"
"${HOME}/.local/bin/ensure-gnome-keyring" || true

desktop_dir="${HOME}/.local/share/applications"
mkdir -p "$desktop_dir"
cat >"${desktop_dir}/code.desktop" <<EOF
[Desktop Entry]
Name=Visual Studio Code
Comment=Code Editor
GenericName=Text Editor
Exec=${HOME}/.local/bin/code --unity-launch %F
Icon=visual-studio-code
Type=Application
StartupNotify=false
StartupWMClass=code-oss
Categories=TextEditor;Development;IDE;
MimeType=application/x-code-workspace;
Actions=new-empty-window;
Keywords=vscode;

[Desktop Action new-empty-window]
Name=New Empty Window
Exec=${HOME}/.local/bin/code --new-window %F
Icon=visual-studio-code
EOF

# Hide the stock Arch "Code - OSS" menu entry; use code.desktop (Hypr Dark Frost X wrapper) instead.
cat >"${desktop_dir}/code-oss.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=Code - OSS
Hidden=true
NoDisplay=true
EOF

if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database "${desktop_dir}" 2>/dev/null || true
fi

echo "VS Code installed and Hypr Dark Frost X theme applied."
echo "Launch with: code   or   ~/.local/bin/code"
