#!/usr/bin/env bash
set -euo pipefail

colors="${HOME}/.cache/ambxst/colors.json"
out="${HOME}/.config/rofi/hypr-dark-frost-xdotfiles-colors.rasi"
rofi_cfg="${HOME}/.config/rofi/config.rasi"
# shellcheck source=/dev/null
source "${HOME}/.local/share/hypr-dark-frost-xdotfiles/font-stack.sh"
hdf_x_font_stack

if [[ ! -f "$colors" ]]; then
    echo "Shell colors not found at $colors" >&2
    exit 1
fi

read_color() {
    jq -r ".[\"$1\"] // empty" "$colors"
}

bg="$(read_color background)"
surface="$(read_color surface)"
surface_high="$(read_color surfaceContainerHigh)"
surface_highest="$(read_color surfaceContainerHighest)"
fg="$(read_color overBackground)"
muted="$(read_color overSurfaceVariant)"
primary="$(read_color primary)"
on_primary="$(read_color overPrimary)"
outline="$(read_color outlineVariant)"
accent="$(read_color tertiary)"

mkdir -p "$(dirname "$out")"

cat >"$out" <<EOF
/* Generated by hypr-dark-frost-xdotfiles colors — rerun: sync-rofi-hypr-dark-frost-xdotfiles */
* {
    hdf-x-bg:              ${bg};
    hdf-x-surface:         ${surface};
    hdf-x-surface-high:    ${surface_high};
    hdf-x-surface-highest: ${surface_highest};
    hdf-x-fg:              ${fg};
    hdf-x-muted:           ${muted};
    hdf-x-primary:         ${primary};
    hdf-x-on-primary:      ${on_primary};
    hdf-x-outline:         ${outline};
    hdf-x-accent:          ${accent};

    background:                  ${surface};
    foreground:                  ${primary};
    normal-foreground:           ${primary};
    alternate-normal-foreground: ${primary};
    selected-normal-foreground:  ${primary};
    active-foreground:           ${primary};
    urgent-foreground:           ${primary};
    normal-background:           transparent;
    alternate-normal-background: transparent;
    selected-normal-background:  ${surface_highest};
    active-background:           transparent;
    urgent-background:           transparent;
    separatorcolor:              transparent;
    border-color:                ${outline};
}
EOF

if [[ -f "$rofi_cfg" ]]; then
    sed -i -E "s/^[[:space:]]*font:.*/    font: \"${HDF_X_ROFI_FONT}\";/" "$rofi_cfg"
fi

echo "Updated $out (font: ${HDF_X_ROFI_FONT})"
