#!/usr/bin/env bash
# hypr-dark-frost-xdotfiles — sync fonts everywhere: fontconfig, GTK, Rofi, Kitty, VS Code, Firefox.
set -euo pipefail

fontconf_dir="${HOME}/.config/fontconfig/conf.d"
fontconf_file="${fontconf_dir}/99-hypr-dark-frost-xdotfiles-fonts.conf"
# shellcheck source=/dev/null
source "${HOME}/.local/share/hypr-dark-frost-xdotfiles/font-stack.sh"
hdf_x_font_stack

mkdir -p "$fontconf_dir"
cat >"$fontconf_file" <<EOF
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<!-- Generated by sync-fonts-hypr-dark-frost-xdotfiles -->
<fontconfig>
  <alias binding="strong">
    <family>sans-serif</family>
    <prefer>
      <family>${HDF_X_UI_FONT}</family>
      <family>SF Pro Text</family>
      <family>SF Pro Display</family>
      <family>Inter</family>
      <family>Noto Sans</family>
    </prefer>
  </alias>
  <alias binding="strong">
    <family>monospace</family>
    <prefer>
      <family>${HDF_X_MONO_FONT}</family>
      <family>SF Mono</family>
      <family>JetBrainsMono Nerd Font Mono</family>
    </prefer>
  </alias>
  <match target="font">
    <test name="family" compare="eq"><string>SF Pro Text</string></test>
    <edit name="hintstyle" mode="assign"><const>hintslight</const></edit>
    <edit name="rgba" mode="assign"><const>rgb</const></edit>
    <edit name="lcdfilter" mode="assign"><const>lcddefault</const></edit>
  </match>
  <match target="font">
    <test name="family" compare="eq"><string>Inter</string></test>
    <edit name="hintstyle" mode="assign"><const>hintslight</const></edit>
    <edit name="rgba" mode="assign"><const>rgb</const></edit>
    <edit name="lcdfilter" mode="assign"><const>lcddefault</const></edit>
  </match>
</fontconfig>
EOF

fc-cache -f >/dev/null 2>&1 || true

bin="${HOME}/.local/bin"
for script in sync-gtk-hypr-dark-frost-xdotfiles sync-rofi-hypr-dark-frost-xdotfiles sync-kitty-hypr-dark-frost-xdotfiles sync-vscode-hypr-dark-frost-xdotfiles; do
    "$bin/$script"
done
"$bin/sync-firefox-hypr-dark-frost-xdotfiles" sync
"$bin/sync-shell-hypr-dark-frost-xdotfiles" 2>/dev/null || true

if ! fc-list "SF Pro Text" -f '%{family}\n' 2>/dev/null | grep -q .; then
    echo ""
    echo "SF Pro is not installed yet. Run:"
    echo "  ~/.local/bin/install-fonts-hypr-dark-frost-xdotfiles"
    echo ""
fi

echo "Font stack: ${HDF_X_UI_FONT} ${HDF_X_UI_SIZE} · ${HDF_X_MONO_FONT} ${HDF_X_MONO_SIZE}"
echo "Reload your shell UI for bar/widget fonts. Restart apps for full effect."
