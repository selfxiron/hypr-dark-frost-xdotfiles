    "panelTitle.inactiveForeground": "${muted}",
    "terminal.background": "${bg}",
    "terminal.foreground": "${fg}",
    "terminal.ansiBlack": "${surface}",
    "terminal.ansiRed": "${error}",
    "terminal.ansiGreen": "#98c379",
    "terminal.ansiYellow": "#e5c07b",
    "terminal.ansiBlue": "${secondary}",
    "terminal.ansiMagenta": "#c678dd",
    "terminal.ansiCyan": "#56b6c2",
    "terminal.ansiWhite": "${fg}",
    "terminal.ansiBrightBlack": "${outline}",
    "terminal.ansiBrightRed": "${error}",
    "terminal.ansiBrightGreen": "#98c379",
    "terminal.ansiBrightYellow": "#e5c07b",
    "terminal.ansiBrightBlue": "${primary}",
    "terminal.ansiBrightMagenta": "#c678dd",
    "terminal.ansiBrightCyan": "#56b6c2",
    "terminal.ansiBrightWhite": "${primary}",
    "input.background": "${surface_container}",
    "input.foreground": "${fg}",
    "input.border": "${outline}",
    "input.placeholderForeground": "${muted}",
    "inputOption.activeBorder": "${primary}",
    "dropdown.background": "${surface_container}",
    "dropdown.foreground": "${fg}",
    "dropdown.border": "${outline}",
    "dialog.background": "${surface_container}",
    "dialog.foreground": "${fg}",
    "dialog.border": "${outline}",
    "dialog.shadow": "#00000066",
    "button.background": "${primary}",
