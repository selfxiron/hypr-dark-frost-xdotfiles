    "notificationCenter.border": "${outline}",
    "notificationCenterHeader.background": "${surface_container}",
    "notificationCenterHeader.foreground": "${fg}",
    "notifications.background": "${surface_container}",
    "notifications.foreground": "${fg}",
    "notifications.border": "${outline}",
    "notificationsErrorIcon.foreground": "${error}",
    "notificationsWarningIcon.foreground": "#e5c07b",
    "notificationsInfoIcon.foreground": "${secondary}",
    "pickerGroup.border": "${outline}",
    "pickerGroup.foreground": "${fg}",
    "quickInput.background": "${surface_container}",
    "quickInput.foreground": "${fg}",
    "quickInputTitle.background": "${surface_high}",
    "keybindingLabel.background": "${surface_high}",
    "keybindingLabel.foreground": "${fg}",
    "keybindingLabel.border": "${outline}",
    "settings.headerForeground": "${fg}",
    "settings.modifiedItemIndicator": "${primary}",
    "settings.dropdownBackground": "${surface_container}",
    "settings.dropdownForeground": "${fg}",
    "settings.dropdownBorder": "${outline}",
    "settings.checkboxBackground": "${surface_container}",
    "settings.checkboxForeground": "${fg}",
    "settings.checkboxBorder": "${outline}",
    "settings.textInputBackground": "${surface_container}",
    "settings.textInputForeground": "${fg}",
    "settings.textInputBorder": "${outline}",
    "settings.numberInputBackground": "${surface_container}",
    "settings.numberInputForeground": "${fg}",
    "settings.numberInputBorder": "${outline}",
    "gitDecoration.modifiedResourceForeground": "#e5c07b",
    "gitDecoration.deletedResourceForeground": "${error}",
    "gitDecoration.untrackedResourceForeground": "#98c379",
    "gitDecoration.ignoredResourceForeground": "${muted}",
    "gitDecoration.conflictingResourceForeground": "#c678dd"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "${muted}", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "constant.other.symbol"],
      "settings": { "foreground": "#98c379" }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": { "foreground": "#e5c07b" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "${primary}" }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": { "foreground": "${secondary}" }
    },
    {
      "scope": ["entity.name.type", "support.type", "support.class"],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "${fg}" }
    },
    {
      "scope": ["entity.name.tag", "markup.heading"],
      "settings": { "foreground": "${error}" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    }
  ]
}
EOF

hdf_x_settings="$(cat <<EOF
{
  "window.titleBarStyle": "custom",
  "window.controlsStyle": "hidden",
  "window.customTitleBarVisibility": "auto",
  "window.menuBarVisibility": "compact",
  "window.commandCenter": false,
  "window.dialogStyle": "custom",
  "window.autoDetectColorScheme": false,
  "workbench.colorTheme": "Hypr Dark Frost X",
  "workbench.preferredDarkColorTheme": "Hypr Dark Frost X",
  "workbench.preferredLightColorTheme": "Hypr Dark Frost X",
  "workbench.fontAliasing": "antialiased",
  "workbench.colorCustomizations": {
    "[Hypr Dark Frost X]": {
      "dialog.background": "${surface_container}",
      "dialog.foreground": "${fg}",
      "dialog.border": "${outline}",
      "button.background": "${primary}",
      "button.foreground": "${bg}",
      "button.hoverBackground": "${secondary}",
      "button.secondaryBackground": "${surface_high}",
      "button.secondaryForeground": "${fg}",
      "button.secondaryHoverBackground": "${surface_highest}",
      "button.secondaryBorder": "${outline}",
      "textPreformat.foreground": "${primary}",
      "textCodeBlock.background": "${surface_high}",
      "textCodeBlock.foreground": "${primary}"
    }
  },
  "workbench.iconTheme": "vs-seti",
  "workbench.startupEditor": "none",
  "workbench.welcome.enabled": false,
  "workbench.tree.indent": 16,
  "workbench.editor.showTabs": "multiple",
  "workbench.activityBar.location": "default",
  "editor.fontFamily": "${mono_font}",
  "editor.fontSize": ${mono_size},
  "editor.codeLensFontFamily": "${ui_font}",
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.lineNumbers": "on",
  "editor.renderLineHighlight": "line",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.smoothScrolling": true,
  "terminal.integrated.fontFamily": "${mono_font}",
  "terminal.integrated.fontSize": ${mono_size},
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.defaultProfile.linux": "bash",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.simpleDialog.enable": true,
  "explorer.compactFolders": false,
  "breadcrumbs.enabled": true,
  "security.workspace.trust.enabled": false
}
EOF
)"

for code_user_dir in "${code_user_dirs[@]}"; do
    mkdir -p "${code_user_dir}/themes"
    cp "$theme_tmp" "${code_user_dir}/themes/hypr-dark-frost-xdotfiles-color-theme.json"
    code_settings="${code_user_dir}/settings.json"

    if [[ -f "$code_settings" ]]; then
        tmp="$(mktemp)"
        jq --argjson hdf_x "$hdf_x_settings" '. * $hdf_x' "$code_settings" >"$tmp"
        mv "$tmp" "$code_settings"
    else
        mkdir -p "$code_user_dir"
        echo "$hdf_x_settings" | jq '.' >"$code_settings"
    fi
done

# Electron flags go in electron42-flags.conf (read by /usr/bin/code-oss), not code-flags.conf.
mkdir -p "${HOME}/.config"
cat >"${HOME}/.config/electron42-flags.conf" <<'EOF'
# VS Code (electron42) — Wayland; no native titlebar buttons (match Cursor).
--enable-features=UseOzonePlatform
--disable-features=WaylandWindowDecorations
--ozone-platform-hint=auto
EOF
# code-flags.conf is passed to code.mjs; keep empty so VS Code doesn't warn on Electron flags.
: >"${HOME}/.config/code-flags.conf"

# Tell VS Code to use gnome-keyring (Secret Service) instead of auto-detecting a DE keyring.
vscode_argv="${HOME}/.vscode-oss/argv.json"
if [[ -f "$vscode_argv" ]] && ! grep -q '"password-store"' "$vscode_argv"; then
    sed -i '/^}$/i\\t"password-store": "gnome-libsecret",' "$vscode_argv"
fi

echo "Updated VS Code Hypr Dark Frost X theme + settings (Code - OSS + Code)"
echo "Frost: hyprland code-frosted rule (0.88 opacity on class Code|code-oss) — run: hyprctl reload"
