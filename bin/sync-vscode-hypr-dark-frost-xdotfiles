    "activityBar.inactiveForeground": "${muted}",
    "activityBar.border": "${outline}",
    "activityBarBadge.background": "${primary}",
    "activityBarBadge.foreground": "${bg}",
    "sideBar.background": "${surface}",
    "sideBar.foreground": "${fg}",
    "sideBar.border": "${outline}",
    "sideBarTitle.foreground": "${fg}",
    "sideBarSectionHeader.background": "${surface_container}",
    "sideBarSectionHeader.foreground": "${fg}",
    "sideBarSectionHeader.border": "${outline}",
    "list.activeSelectionBackground": "${surface_highest}",
    "list.activeSelectionForeground": "${fg}",
    "list.inactiveSelectionBackground": "${surface_high}",
    "list.inactiveSelectionForeground": "${fg}",
    "list.hoverBackground": "${surface_high}",
    "list.hoverForeground": "${fg}",
