    "tab.activeBorderTop": "${primary}",
    "tab.hoverBackground": "${surface_high}",
    "tab.unfocusedActiveBackground": "${surface_container}",
    "tab.unfocusedInactiveBackground": "${surface}",
    "titleBar.activeBackground": "${surface}",
    "titleBar.activeForeground": "${fg}",
    "titleBar.inactiveBackground": "${surface}",
    "titleBar.inactiveForeground": "${muted}",
    "titleBar.border": "${outline}",
    "menubar.selectionBackground": "${surface_highest}",
    "menubar.selectionForeground": "${fg}",
    "menu.background": "${surface_container}",
    "menu.foreground": "${fg}",
    "menu.selectionBackground": "${surface_highest}",
    "menu.selectionForeground": "${fg}",
    "menu.separatorBackground": "${outline}",
    "menu.border": "${outline}",
    "statusBar.background": "${surface}",
    "statusBar.foreground": "${muted}",
    "statusBar.border": "${outline}",
    "statusBar.debuggingBackground": "${error_container}",
    "statusBar.debuggingForeground": "${fg}",
    "statusBar.noFolderBackground": "${surface_container}",
    "statusBarItem.activeBackground": "${surface_highest}",
    "statusBarItem.hoverBackground": "${surface_high}",
