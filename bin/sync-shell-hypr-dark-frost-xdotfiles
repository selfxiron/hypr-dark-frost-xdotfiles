#!/usr/bin/env bash
# hypr-dark-frost-xdotfiles — Fastfetch + Starship from shell colors.
set -euo pipefail

colors="${HOME}/.cache/ambxst/colors.json"
out_ff="${HOME}/.config/fastfetch/config.jsonc"
out_starship="${HOME}/.config/starship.toml"
# shellcheck source=/dev/null
source "${HOME}/.local/share/hypr-dark-frost-xdotfiles/font-stack.sh"

if [[ ! -f "$colors" ]]; then
    echo "Shell colors not found at $colors" >&2
    exit 1
fi

read_color() {
    jq -r ".[\"$1\"] // empty" "$colors"
}

hdf_x_font_stack

bg="$(read_color background)"
fg="$(read_color overBackground)"
muted="$(read_color overSurfaceVariant)"
primary="$(read_color primary)"
surface="$(read_color surface)"
error="$(read_color error)"
outline="$(read_color outlineVariant)"

mkdir -p "${HOME}/.config/fastfetch"

cat >"$out_ff" <<EOF
{
  "\$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "small",
    "padding": {
      "top": 1,
      "left": 2
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "${muted}",
      "title": "${primary}"
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "wm",
    "shell",
    "terminal",
    "packages",
    "uptime",
    "memory",
    "disk",
    "break",
    "colors"
  ]
}
EOF

cat >"$out_starship" <<EOF
# Generated by sync-shell-hypr-dark-frost-xdotfiles

add_newline = false
command_timeout = 500
format = "\$directory\$git_branch\$git_status\$fill\$character"

[fill]
symbol = " "

[character]
success_symbol = "[❯](${primary})"
error_symbol = "[❯](${error})"
vimcmd_symbol = "[❮](${muted})"
vimcmd_replace_one_symbol = "[❮](${muted})"
vimcmd_replace_symbol = "[❮](${muted})"
vimcmd_visual_symbol = "[❮](${muted})"

[directory]
style = "bold ${primary}"
read_only = "  "
truncation_length = 4
truncate_to_repo = true
format = "[\$path](\$style)\$read_only "

[git_branch]
symbol = ""
style = "${muted}"
format = "[\$symbol\$branch](\$style) "

[git_status]
style = "${error}"
format = "[\$all_status\$ahead_behind](\$style) "

[cmd_duration]
min_time = 2000
style = "${muted}"
format = "took [\$duration](\$style) "

[time]
disabled = true

[username]
show_always = false

[hostname]
ssh_only = true
EOF

echo "Updated Fastfetch: ${out_ff}"
echo "Updated Starship: ${out_starship} (mono: ${HDF_X_MONO_FONT} via Kitty)"
